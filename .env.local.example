# ============================================================
# ENVIRONMENT VARIABLES TEMPLATE
# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in your values from Supabase Dashboard
# 3. NEVER commit .env.local to git
# ============================================================

# --- SUPABASE ---
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — ONLY use server-side, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- LINE Messaging API ---
# Create a Messaging API channel at: https://developers.line.biz/console/
# Channel Access Token: Console → Messaging API → Issue token
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
# Channel Secret: Console → Basic settings
LINE_CHANNEL_SECRET=your-line-channel-secret
# Channel ID: Console → Basic settings
LINE_CHANNEL_ID=your-line-channel-id

# --- CRON ---
# Random 32-char string to secure /api/cron/* routes.
# Generate with: openssl rand -hex 16
CRON_SECRET=your-cron-secret
